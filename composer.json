{
	"name": "xwp/custom-xml-sitemap",
	"description": "Custom taxonomy-based XML sitemap generator for WordPress.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"wordpress",
		"sitemap",
		"xml-sitemap",
		"seo",
		"taxonomy"
	],
	"homepage": "https://github.com/xwp/custom-xml-sitemap",
	"authors": [
		{
			"name": "XWP",
			"homepage": "https://xwp.co"
		}
	],
	"support": {
		"issues": "https://github.com/xwp/custom-xml-sitemap/issues",
		"source": "https://github.com/xwp/custom-xml-sitemap"
	},
	"require": {
		"php": "^8.4",
		"composer/installers": "^1.0 || ^2.0",
		"woocommerce/action-scheduler": "^3.9"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6",
		"phpstan/phpstan": "^1.10",
		"szepeviktor/phpstan-wordpress": "^1.3",
		"automattic/vipwpcs": "^3.0",
		"brain/monkey": "^2.6",
		"wp-cli/wp-cli": "^2.12",
		"yoast/phpunit-polyfills": "^2.0"
	},
	"autoload": {
		"psr-4": {
			"XWP\\CustomXmlSitemap\\": "src/"
		}
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"extra": {
		"installer-paths": {
			"vendor/{$vendor}/{$name}": ["woocommerce/action-scheduler"]
		}
	},
	"scripts": {
		"lint": "phpcs",
		"lint:fix": "phpcbf",
		"phpstan": "phpstan analyze",
		"phpunit": "phpunit",
		"phpunit:unit": "phpunit --testsuite=unit",
		"phpunit:integration": "phpunit -c phpunit-integration.xml.dist",
		"test": [
			"@lint",
			"@phpstan",
			"@phpunit:unit"
		]
	}
}
